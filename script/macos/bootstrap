#!/bin/sh
#
# Prepare a local Warp Lite checkout for building the terminal-only target.

set -e

if ! command -v cargo >/dev/null 2>&1; then
    echo "Rust/Cargo is required. Install Rust from https://rustup.rs, then rerun this script."
    exit 1
fi

if ! xcode-select -p >/dev/null 2>&1; then
    echo "Xcode command line tools are required for macOS builds."
    echo "Run: xcode-select --install"
    exit 1
fi

echo "Warp Lite bootstrap complete. Build with: cargo check -p warp --bin warp-oss"
